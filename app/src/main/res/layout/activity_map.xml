<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#191022">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#191022"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:background="@drawable/bg_rounded">

            <ImageView
                android:id="@+id/icon_back"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_icon" />
        </LinearLayout>

        <TextView
            android:id="@+id/txt_header_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Od kod si pa ti?"
            android:textColor="#FF8C00"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- BOTTOM NAV -->
    <LinearLayout
        android:id="@+id/bottom_navigation_bar"
        android:layout_width="0dp"
        android:layout_height="76dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#F2191022"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/icon_home"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_icon" />

            <TextView
                android:id="@+id/text_home"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="DOMOV"
                android:textSize="10sp"
                android:textColor="#94A3B8" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_map"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/icon_map"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_icon" />

            <TextView
                android:id="@+id/text_map"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="ZEMLJEVID"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#FF8C00" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_events"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/icon_events"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_icon" />

            <TextView
                android:id="@+id/text_events"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="DOGODKI"
                android:textSize="10sp"
                android:textColor="#94A3B8" />
        </LinearLayout>
    </LinearLayout>

    <!-- MAIN -->
    <ScrollView
        android:id="@+id/main_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- MAP CARD -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/map_card"
                android:layout_width="match_parent"
                android:layout_height="224dp"
                android:background="@drawable/bg_rounded">

                <androidx.fragment.app.FragmentContainerView
                    android:id="@+id/map_fragment_container"
                    android:name="com.google.android.gms.maps.SupportMapFragment"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/txt_city_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LJUBLJANA"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_rounded"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    android:layout_marginTop="110dp"
                    android:layout_marginStart="160dp" />

                <LinearLayout
                    android:id="@+id/map_text_box"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp"
                    android:layout_marginBottom="16dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <TextView
                        android:id="@+id/txt_active_region_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AKTIVNA REGIJA"
                        android:textColor="#FF8C00"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/txt_active_region"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Osrednjeslovenska"
                        android:textColor="#F1F5F9"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- REGION FILTERS -->
            <HorizontalScrollView
                android:id="@+id/region_scroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btn_region_osrednja"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="Osrednjeslovenska"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:background="@drawable/bg_rounded"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:id="@+id/btn_region_podravska"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="Podravska"
                        android:textColor="#CBD5E1"
                        android:background="@drawable/bg_rounded"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:id="@+id/btn_region_obalna"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="Obalno-kraška"
                        android:textColor="#CBD5E1"
                        android:background="@drawable/bg_rounded"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:id="@+id/btn_region_savinjska"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="Savinjska"
                        android:textColor="#CBD5E1"
                        android:background="@drawable/bg_rounded"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- SECTION TITLE -->
            <LinearLayout
                android:id="@+id/section_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/txt_section_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Lokalne legende"
                    android:textColor="#F1F5F9"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txt_comedian_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12 KOMIKOV"
                    android:textColor="#FF8C00"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- CARD 1 -->
            <LinearLayout
                android:id="@+id/comedian_card_1"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_rounded"
                android:padding="12dp">

                <View
                    android:id="@+id/img_comedian_1"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="#6E7B5A" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txt_comedian_name_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vid Valič"
                        android:textColor="#F1F5F9"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txt_comedian_location_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ljubljana"
                        android:textColor="#94A3B8"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_card_1"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:background="@drawable/bg_rounded">

                    <ImageView
                        android:id="@+id/icon_card_1"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_icon" />
                </LinearLayout>
            </LinearLayout>

            <!-- CARD 2 -->
            <LinearLayout
                android:id="@+id/comedian_card_2"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_rounded"
                android:padding="12dp">

                <View
                    android:id="@+id/img_comedian_2"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="#AA6A6F" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txt_comedian_name_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Martina Ipša"
                        android:textColor="#F1F5F9"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txt_comedian_location_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Maribor (Podravska)"
                        android:textColor="#94A3B8"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_card_2"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:background="@drawable/bg_rounded">

                    <ImageView
                        android:id="@+id/icon_card_2"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_icon" />
                </LinearLayout>
            </LinearLayout>

            <!-- CARD 3 -->
            <LinearLayout
                android:id="@+id/comedian_card_3"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_rounded"
                android:padding="12dp">

                <View
                    android:id="@+id/img_comedian_3"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="#8C7E54" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txt_comedian_name_3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Perica Jerković"
                        android:textColor="#F1F5F9"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txt_comedian_location_3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ljubljana"
                        android:textColor="#94A3B8"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_card_3"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:background="@drawable/bg_rounded">

                    <ImageView
                        android:id="@+id/icon_card_3"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_icon" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>