<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF191022">



    <!-- Top Navigation -->
    <LinearLayout
        android:id="@+id/top_navigation"
        android:orientation="horizontal"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:background="#FF191022"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:background="@drawable/bg_rounded">

            <ImageView
                android:id="@+id/top_nav_left_icon"
                android:src="@drawable/ic_nazaj"
                android:scaleType="fitXY"
                android:layout_width="16dp"
                android:layout_height="16dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/top_nav_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="Dogodek"
            android:textColor="#FF8C00"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Main Content with ScrollView -->
    <ScrollView
        android:id="@+id/main_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/top_navigation"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:gravity="center_horizontal">

        <LinearLayout
            android:id="@+id/main_content"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:paddingBottom="20dp">

        <!-- Hero Image -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/hero_image"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:background="#33FF8C00">

            <ImageView
                android:id="@+id/event_hero_image"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:scaleType="centerCrop"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <LinearLayout
                android:id="@+id/hero_gradient"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:orientation="horizontal"
                android:background="#99000000"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Event Title -->
        <LinearLayout
            android:id="@+id/event_title_section"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingLeft="16dp"
            android:paddingTop="32dp"
            android:paddingRight="16dp">

            <LinearLayout
                android:id="@+id/event_category_container"
                android:orientation="horizontal"
                android:layout_width="153dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_rounded"
                android:paddingLeft="12dp"
                android:paddingTop="4dp"
                android:paddingRight="12dp">

                <TextView
                    android:id="@+id/event_category_text"
                    android:text="Stand-up Komedija"
                    android:textSize="12sp"
                    android:textColor="#FFFF8C00"
                    android:textStyle="bold"
                    android:fontFamily="Space Grotesk"
                    android:layout_width="129dp"
                    android:layout_height="16dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/event_title_container"
                android:orientation="vertical"
                android:layout_width="358dp"
                android:layout_height="45dp">

                <TextView
                    android:id="@+id/event_title"
                    android:text="Vid Valič: Stradanje"
                    android:textSize="36sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:fontFamily="Space Grotesk"
                    android:layout_width="358dp"
                    android:layout_height="45dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Event Info Grid -->
        <LinearLayout
            android:id="@+id/event_info_grid"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingLeft="8dp"
            android:paddingRight="8dp">

            <!-- Date & Time -->
            <LinearLayout
                android:id="@+id/event_datetime_container"
                android:orientation="horizontal"
                android:layout_width="374dp"
                android:layout_height="72dp"
                android:padding="16dp">

                <LinearLayout
                    android:id="@+id/event_datetime_icon_container"
                    android:orientation="horizontal"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_rounded">

                    <ImageView
                        android:id="@+id/event_datetime_icon"
                        android:src="@drawable/ic_dogodek"
                        android:scaleType="fitXY"
                        android:layout_width="18dp"
                        android:layout_height="20dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/event_datetime_text_container"
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/event_date_text"
                        android:text="Petek, 20. oktober • 20:00"
                        android:textSize="16sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:fontFamily="Space Grotesk"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:id="@+id/event_doors_text"
                        android:text="Vrata se odprejo ob 19:30"
                        android:textSize="14sp"
                        android:textColor="#94A3B8"
                        android:fontFamily="Space Grotesk"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </LinearLayout>

            <!-- Venue -->
            <LinearLayout
                android:id="@+id/event_venue_container"
                android:orientation="horizontal"
                android:layout_width="374dp"
                android:layout_height="82dp"
                android:padding="16dp">

                <LinearLayout
                    android:id="@+id/event_venue_icon_container"
                    android:orientation="horizontal"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_rounded">

                    <ImageView
                        android:id="@+id/event_venue_icon"
                        android:src="@drawable/ic_zemljevid"
                        android:scaleType="fitXY"
                        android:layout_width="16dp"
                        android:layout_height="20dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/event_venue_text_container"
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/event_venue_title"
                        android:text="Kino Šiška"
                        android:textSize="16sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:fontFamily="Space Grotesk"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:id="@+id/event_venue_address"
                        android:text="Trg prekomorskih brigad 3, 1000 Ljubljana"
                        android:textSize="14sp"
                        android:textColor="#94A3B8"
                        android:fontFamily="Space Grotesk"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Description -->
        <LinearLayout
            android:id="@+id/event_description_section"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingLeft="16dp"
            android:paddingTop="40dp"
            android:paddingRight="16dp">

            <TextView
                android:id="@+id/event_description_title"
                android:text="O dogodku"
                android:textSize="18sp"
                android:textColor="#FF8C00"
                android:textStyle="bold"
                android:fontFamily="Space Grotesk"
                android:layout_width="358dp"
                android:layout_height="28dp" />

            <TextView
                android:id="@+id/event_description_text"
                android:text="Pridružite se Vidu Valiču v njegovi najnovejši stand-up uspešnici 'Stradanje'. Svež material, oster humor in nepozaben večer smeha v osrčju Ljubljane. Ne zamudite enega najbolj priljubljenih slovenskih komikov v živo."
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:fontFamily="Space Grotesk"
                android:layout_width="358dp"
                android:layout_height="130dp" />
        </LinearLayout>

        <!-- Map Placeholder -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/map_placeholder"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_rounded">

            <LinearLayout
                android:id="@+id/map_overlay"
                android:orientation="horizontal"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_margin="1dp"
                android:background="#33191022"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <LinearLayout
                    android:id="@+id/map_icon_container"
                    android:orientation="vertical"
                    android:layout_width="32dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_rounded"
                    android:padding="8dp">

                    <LinearLayout
                        android:id="@+id/map_icon_shadow"
                        android:layout_width="32dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_rounded"
                        android:orientation="horizontal" />

                    <ImageView
                        android:id="@+id/map_icon"
                        android:src="@drawable/ic_zemljevid"
                        android:scaleType="fitXY"
                        android:layout_width="16dp"
                        android:layout_height="20dp" />
                </LinearLayout>
            </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>