<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#191022">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER IMAGE -->
        <ImageView
            android:id="@+id/img_header"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_icon" />

        <!-- CONTENT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- NAME -->
            <TextView
                android:id="@+id/txt_comedian_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ime Komika"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />

            <!-- SUBTITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Slovenski komik"
                android:textColor="#94A3B8"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />

            <!-- BIO SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Biografija"
                android:textColor="#FF8C00"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp" />

            <TextView
                android:id="@+id/txt_bio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tukaj pride opis komika..."
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginTop="8dp" />

            <!-- STYLE SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Slog"
                android:textColor="#FF8C00"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp" />

            <TextView
                android:id="@+id/txt_style"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Stand-up, Humor"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginTop="8dp" />

            <!-- MEDIA SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mediji in posnetki"
                android:textColor="#FF8C00"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp" />

            <LinearLayout
                android:id="@+id/layout_media_links"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp">
                <!-- YouTube links will be added here dynamically -->
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
