<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#191022">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="61dp"
        android:orientation="horizontal"
        android:background="#CC191022"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/btn_menu"
            android:layout_width="34dp"
            android:layout_height="28dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_rounded"
            android:padding="8dp">

            <ImageView
                android:id="@+id/img_menu"
                android:layout_width="18dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_icon"
                android:scaleType="fitCenter" />
        </LinearLayout>

        <TextView
            android:id="@+id/txt_header_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:text="Slovenski smeh"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FF8C00"
            android:fontFamily="sans-serif" />
    </LinearLayout>

    <!-- BOTTOM NAV -->
    <LinearLayout
        android:id="@+id/bottom_navigation_bar"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:background="#F2191022"
        android:gravity="center"
        android:paddingStart="24dp"
        android:paddingTop="8dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/icon_home"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_icon" />

            <TextView
                android:id="@+id/text_home"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Domov"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#FF8C00" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_map"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/icon_map"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_icon" />

            <TextView
                android:id="@+id/text_map"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Zemljevid"
                android:textSize="10sp"
                android:textColor="#94A3B8" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_events"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/icon_events"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_icon" />

            <TextView
                android:id="@+id/text_events"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Dogodki"
                android:textSize="10sp"
                android:textColor="#94A3B8" />
        </LinearLayout>
    </LinearLayout>

    <!-- MAIN CONTENT -->
    <ScrollView
        android:id="@+id/main_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/main_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <!-- SEARCH -->
            <LinearLayout
                android:id="@+id/search_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_rounded"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="17dp"
                android:paddingBottom="17dp">

                <ImageView
                    android:id="@+id/icon_search"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_icon" />

                <TextView
                    android:id="@+id/txt_search_placeholder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Išči komike..."
                    android:textSize="16sp"
                    android:textColor="#64748B" />
            </LinearLayout>

            <!-- SECTION HEADER -->
            <LinearLayout
                android:id="@+id/section_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/txt_section_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Vsi komiki"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#F1F5F9" />

                <TextView
                    android:id="@+id/btn_show_all"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Prikaži vse"
                    android:textSize="14sp"
                    android:textColor="#FF8C00" />
            </LinearLayout>

            <!-- GRID -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/comedians_grid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp">

                <!-- Comedian 1 -->
                <LinearLayout
                    android:id="@+id/comedian_1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_rounded"
                    app:layout_constraintWidth_percent="0.48"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <View
                        android:id="@+id/image_1"
                        android:layout_width="match_parent"
                        android:layout_height="169dp"
                        android:background="#E7C3A5" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/txt_name_1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Vid Valič"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#F1F5F9" />

                        <TextView
                            android:id="@+id/txt_quote_1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="&quot;Everything is a wedding.&quot;"
                            android:textSize="12sp"
                            android:textColor="#94A3B8" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Comedian 2 -->
                <LinearLayout
                    android:id="@+id/comedian_2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_rounded"
                    app:layout_constraintWidth_percent="0.48"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <View
                        android:id="@+id/image_2"
                        android:layout_width="match_parent"
                        android:layout_height="169dp"
                        android:background="#446B53" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/txt_name_2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Martina Ipša"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#F1F5F9" />

                        <TextView
                            android:id="@+id/txt_quote_2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="&quot;Styrian soul, global jokes.&quot;"
                            android:textSize="12sp"
                            android:textColor="#94A3B8" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Comedian 3 -->
                <LinearLayout
                    android:id="@+id/comedian_3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_rounded"
                    app:layout_constraintWidth_percent="0.48"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/comedian_1">

                    <View
                        android:id="@+id/image_3"
                        android:layout_width="match_parent"
                        android:layout_height="169dp"
                        android:background="#D98A91" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/txt_name_3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tilen Artač"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#F1F5F9" />

                        <TextView
                            android:id="@+id/txt_quote_3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="&quot;The voice of a thousand people.&quot;"
                            android:textSize="12sp"
                            android:textColor="#94A3B8" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Comedian 4 -->
                <LinearLayout
                    android:id="@+id/comedian_4"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_rounded"
                    app:layout_constraintWidth_percent="0.48"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/comedian_2">

                    <View
                        android:id="@+id/image_4"
                        android:layout_width="match_parent"
                        android:layout_height="169dp"
                        android:background="#2A2A2A" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/txt_name_4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lucija Ćirović"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#F1F5F9" />

                        <TextView
                            android:id="@+id/txt_quote_4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="&quot;From puppets to punchlines.&quot;"
                            android:textSize="12sp"
                            android:textColor="#94A3B8" />
                    </LinearLayout>
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>